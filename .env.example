# ─── NEXUS Trading — environment template ────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit credentials.

# ═══ Database — Supabase Postgres ════════════════════════════════════════════
# Get from: Supabase dashboard → Project Settings → Database → Connection string
# Use the **Transaction Mode** pooler URL (port 6543, ?pgbouncer=true).
# The direct/session URL (port 5432) will run out of connections under load.
#
# Format: postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
#
DATABASE_URL=

# Set to 1 to log every SQL statement Drizzle issues (handy for screener tuning, noisy in prod).
DB_LOG=0


# ═══ Cloudflare R2 — OHLCV warehouse (parquet store) ══════════════════════════
# ⚠ Skipped for the beta — not needed for Phase 2 (fundamentals + screener +
# equity research).  Required later for pattern detection cron.  When you're
# ready, the in-house alternative is Supabase Storage (1GB free, same account
# you already have, S3-compatible — db/r2.ts works with it after a 2-line
# endpoint swap).  Leave these blank and the app's R2 client logs a single
# harmless warning at startup.
#
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=nexus-ohlcv


# ═══ Upstash Redis — hot quote cache + rate-limit buckets ════════════════════
# ⚠ Skipped for the beta — db/redis.ts has an in-memory fallback that's fine
# at single-instance / low-traffic.  Add Upstash later (or any other Redis
# provider) when you hit cross-instance cache needs.
#
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=


# ═══ Existing keys ═══════════════════════════════════════════════════════════
# Market data
FINNHUB_API_KEY=
ALPHA_VANTAGE_KEY=
NEWS_API_KEY=
FRED_API_KEY=
YOUTUBE_API_KEY=

# AI providers (at least one)
GROK_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Branding
NEXT_PUBLIC_APP_NAME=NEXUS
